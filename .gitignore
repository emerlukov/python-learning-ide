# ======================
# Файлы, создаваемые Buildozer при сборке APK
# ======================
.buildozer/
bin/
*.apk
*.aab
*.zip

# ======================
# Кэш и скомпилированные файлы Python
# ======================
__pycache__/
*.py[cod]
*.so
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/

# ======================
# Виртуальное окружение
# ======================
.venv/
venv/
ENV/
env/

# ======================
# Данные coverage (покрытие тестами)
# ======================
.coverage
.coveragecrc
htmlcov/
.coverage.*
*.cover

# ======================
# Файлы Android Studio
# ======================
*.iml
.gradle/
local.properties
android_local.properties

# ======================
# Среды разработки (IDE)
# ======================
.idea/
.vscode/
*.swp
*.swo
*~

# ======================
# Системные файлы
# ======================
.DS_Store
Thumbs.db
desktop.ini

# ======================
# Лог-файлы приложения
# ======================
*.log
app_debug.log
app_error.log

# ======================
# Локальные данные и сохранения
# ======================
data/*.json
!data/examples.json    # ИСКЛЮЧЕНИЕ: examples.json нужно сохранить
language.txt
tabs.json
autosave.py
emergency_backup.py

# ======================
# Временные/мусорные файлы
# ======================
*.tmp
*.bak

# ======================
# Pre-commit (локальные настройки)
# ======================
.pre-commit/
.pre-commit-config.local.yaml

# ======================
# Другое
# ======================
*.pyo
*.pyd
*.orig
*.rej
